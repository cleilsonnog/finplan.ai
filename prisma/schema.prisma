// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CustomCategory {
  id           String        @id @default(uuid())
  userId       String
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name])
}

model Transaction {
  id               String                   @id @default(uuid())
  name             String
  type             TransactionType
  amount           Decimal                  @db.Decimal(10, 2)
  category         TransactionCategory
  paymentMethod    TransactionPaymentMethod
  date             DateTime
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  userId           String
  installments     Int                      @default(1)
  installmentNumber Int                     @default(1)
  creditCardId     String?
  creditCard       CreditCard?              @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  customCategoryId String?
  customCategory   CustomCategory?          @relation(fields: [customCategoryId], references: [id], onDelete: SetNull)
}

enum TransactionType {
  DEPOSIT
  EXPENSE
  INVESTMENT
}

enum TransactionCategory {
  HOUSING
  TRANSPORTATION
  FOOD
  ENTERTAINMENT
  HEALTH
  UTILITY
  SALARY
  EDUCATION
  OTHER
}

enum TransactionPaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  BANK_SLIP
  CASH
  PIX
  OTHER
}

enum CardBrand {
  VISA
  MASTERCARD
  ELO
  AMEX
  HIPERCARD
  OTHER
}

model Budget {
  id               String              @id @default(uuid())
  userId           String
  category         TransactionCategory
  amount           Decimal             @db.Decimal(10, 2)
  month            Int
  year             Int
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  customCategoryId String?
  customCategory   CustomCategory?     @relation(fields: [customCategoryId], references: [id], onDelete: SetNull)

  @@unique([userId, category, customCategoryId, month, year])
}

model CreditCard {
  id             String        @id @default(uuid())
  userId         String
  name           String
  lastFourDigits String
  brand          CardBrand
  bank           String
  limit          Decimal       @db.Decimal(10, 2)
  closingDay     Int
  dueDay         Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transactions   Transaction[]
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model AccountShare {
  id        String   @id @default(uuid())
  ownerId   String
  memberId  String   @unique
  createdAt DateTime @default(now())
}

model AccountShareInvite {
  id           String       @id @default(uuid())
  ownerId      String
  invitedEmail String
  status       InviteStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}